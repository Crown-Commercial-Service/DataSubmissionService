%header.govuk-header{"data-module" => "govuk-header", :role => "banner"}
  .govuk-header__container.govuk-width-container
    .govuk-header__logo
      %a.govuk-header__link.govuk-header__link--homepage{:href => "https://www.gca.gov.uk/"}
        %span.govuk-header__logotype-text.govuk-visually-hidden
          Government
          %br
          Commercial
          %br
          Agency
    .govuk-header__content
      %h1.govuk-heading-l.govuk-header__service-name
        Report management information to GCA
      - if current_user_id
        %button.govuk-header__menu-button.govuk-js-header-toggle{"aria-controls" => "navigation", "aria-label" => "Show or hide Top Level Navigation", :role => "button"} Menu
        - if !no_navigation
          %nav#navigation.govuk-header__navigation{"aria-label" => "Top Level Navigation"}
            %ul.govuk-header__navigation-list
              - if current_user_id
                %li.govuk-header__navigation-item
                  = link_to 'Tasks', tasks_path, {:class=>"govuk-header__link"}
                %li.govuk-header__navigation-item
                  = link_to 'Completed tasks', history_tasks_path, {:class=>"govuk-header__link"}
                %li.govuk-header__navigation-item
                  = link_to 'Agreements', agreements_path, {:class=>"govuk-header__link"}
                %li.govuk-header__navigation-item
                  = link_to 'URN list', urns_path, {:class=>"govuk-header__link"}
                %li.govuk-header__navigation-item
                  = link_to 'User profile', user_detail_path, {:class=>"govuk-header__link"}
                %li.govuk-header__navigation-item
                  = link_to 'Release notes', release_notes_path, {:class=>"govuk-header__link"}
                %li.govuk-header__navigation-item
                  = link_to 'Help', support_path, {:class=>"govuk-header__link"}
                %li.govuk-header__navigation-item
                  = link_to "Sign out", '/sign_out', {:class=>"govuk-header__link"}
